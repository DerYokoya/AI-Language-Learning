### Required ###

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/ai_language_learning

# OpenRouter AI API key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# JWT secret for access tokens
JWT_SECRET=your_jwt_secret_here

### Optional ###

# Server configuration (defaults to 3000 if omitted)
PORT=3000

# refresh token secret. If omitted, falls back to JWT_SECRET + "_refresh"
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Environment (development, test, production)
NODE_ENV=development